# ==============================================================================
# Environment Configuration Example
# ==============================================================================
# Note: Do not place actual plain text secrets or passwords in this file.

# NODE_ENV
# Description: Defines the environment the application is running in.
# Allowed Values: development, test, production
# Default: development
NODE_ENV=development

# DATABASE_URL
# Description: Connection string for the primary PostgreSQL database.
# Format: postgresql://[user]:[password]@[host]:[port]/[db]?schema=[schema]
# REQUIRED
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# POSTGRES_URL_NON_POOLING
# Description: Connection string for the shadow database used by Prisma for migrations.
# This should connect directly to the database without a connection pooler.
# OPTIONAL
POSTGRES_URL_NON_POOLING="postgresql://user:password@localhost:5432/mydb_shadow?schema=public"

# ADMIN_PASSWORD
# Description: Cryptographic hash of the administrative password.
# REQUIRED
# Note: Sensitive! Do not use plain text passwords.
# Format: scrypt:[saltBase64]:[keyBase64]
# Instructions: You must generate an scrypt hash of your password.
# Use a standard scrypt generator to generate this value.
ADMIN_PASSWORD="scrypt:c2FsdA==:aGFzaA=="

# HISTORY_VERSION_LIMIT
# Description: System limit for the number of history versions to keep for content entries.
# Default: 50
HISTORY_VERSION_LIMIT=50

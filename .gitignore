# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Testing
/coverage

# Next.js & Turbopack
/.next/
/.turbo/
/out/

# Production
/build

# Misc
.DS_Store
*.pem

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local Environment Variables
.env*.local
.env

# Prisma
# Ignore generic SQLite database files (in case of accidental local creation)
*.db
*.db-journal
*.sqlite
# Ignore generated Prisma client
node_modules/@prisma/client

# Editor directories and files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace

# IDEs and configuration files
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# macOS file attributes
._*
.vercel

# Jules
.jules/
.Jules/
test-results/

# TypeScript
tsconfig.tsbuildinfo

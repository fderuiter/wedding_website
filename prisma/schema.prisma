// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client" // Add recommended output path
}

datasource db {
  provider = "postgresql"
}

model AppConfig {
  id               String   @id @default("global")
  brideName        String   @default("Bride")
  groomName        String   @default("Groom")
  weddingDate      DateTime @default(dbgenerated("NOW()"))
  baseUrl          String   @default("https://example.com")
  venueName        String   @default("Wedding Venue")
  venueAddress     String   @default("123 Wedding St")
  venueCity        String   @default("City")
  venueState       String   @default("State")
  venueZip         String   @default("12345")
  latitude         Float    @default(0.0)
  longitude        Float    @default(0.0)
  storyText        String   @default("Our story began...")
  venueDescription String   @default("A beautiful venue...")
  travelAdvice     String   @default("Travel safely...")
  heroTitle        String   @default("We Tied the Knot!")
  heroSubtitle     String   @default("Thank you for celebrating with us!")
  seoTitle         String   @default("Our Wedding")
  seoDescription   String   @default("Join us to celebrate our wedding.")
  adminPassword    String   @default("$2b$10$Ep3/07xWd34e9/jV91KIn.u2L1xW5G5S3T.eP28j8/qX5x81A0xLq") // hashed "admin"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WeddingPartyMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  bio       String
  photo     String
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attraction {
  id          String   @id @default(uuid())
  name        String
  description String
  image       String?
  category    String
  website     String
  directions  String
  latitude    Float
  longitude   Float
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RegistryItem {
  id                String       @id @default(uuid())
  name              String
  description       String
  category          String
  price             Float
  image             String
  vendorUrl         String?
  quantity          Int
  isGroupGift       Boolean      @default(false)
  purchased         Boolean      @default(false)
  purchaserName     String?
  amountContributed Float        @default(0)
  contributors      Contributor[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Contributor {
  id            String       @id @default(uuid())
  name          String
  amount        Float
  date          DateTime
  registryItem  RegistryItem @relation(fields: [registryItemId], references: [id], onDelete: Cascade)
  registryItemId String
}

model ContentNode {
  id        String   @id @default(uuid())
  type      String   // e.g., "FAQ", "Logistics", "Photo"
  tags      String[] // e.g., ["Homepage", "FAQ"]
  data      Json     // Flexible key-value pairs
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

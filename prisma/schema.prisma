// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client" // Add recommended output path
}

datasource db {
  provider = "postgresql"
}

model AppConfig {
  id               String   @id @default("global")
  brideName        String   @default("")
  groomName        String   @default("")
  weddingDate      DateTime @default(dbgenerated("NOW()"))
  baseUrl          String   @default("")
  venueName        String   @default("")
  venueAddress     String   @default("")
  venueCity        String   @default("")
  venueState       String   @default("")
  venueZip         String   @default("")
  latitude         Float    @default(0.0)
  longitude        Float    @default(0.0)
  storyText        String   @default("")
  venueDescription String   @default("")
  travelAdvice     String   @default("")
  heroTitle        String   @default("")
  heroSubtitle     String   @default("")
  seoTitle         String   @default("")
  seoDescription   String   @default("")
  adminPassword    String   @default("$2b$10$Ep3/07xWd34e9/jV91KIn.u2L1xW5G5S3T.eP28j8/qX5x81A0xLq") // hashed "admin"
  themePrimary     String   @default("#f43f5e") // rose-500
  themeSecondary   String   @default("#fbbf24") // amber-400
  themeAccent      String   @default("#e11d48") // rose-600
  faviconUrl       String   @default("/assets/favicon.png")
  ogImageUrl       String   @default("/images/sunset-embrace.jpg")
  seoKeywords      String   @default("{{brideName}} and {{groomName}}'s wedding, wedding website, {{venueName}} wedding, {{venueCity}} {{venueState}} wedding, {{brideName}} and {{groomName}} registry, wedding details, wedding ceremony, wedding reception")
  features         Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Media {
  id           String               @id @default(uuid())
  url          String
  altText      String?
  isDecorative Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  weddingPartyMembers WeddingPartyMember[]
  attractions         Attraction[]
  registryItems       RegistryItem[]
}

model WeddingPartyMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  bio       String
  photoId   String
  photo     Media    @relation(fields: [photoId], references: [id])
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attraction {
  id          String   @id @default(uuid())
  name        String
  description String
  imageId     String?
  image       Media?   @relation(fields: [imageId], references: [id])
  category    String
  website     String
  directions  String
  latitude    Float
  longitude   Float
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RegistryItem {
  id                String       @id @default(uuid())
  name              String
  description       String
  category          String
  price             Float
  imageId           String
  image             Media        @relation(fields: [imageId], references: [id])
  vendorUrl         String?
  quantity          Int
  isGroupGift       Boolean      @default(false)
  purchased         Boolean      @default(false)
  purchaserName     String?
  amountContributed Float        @default(0)
  contributors      Contributor[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Contributor {
  id              String       @id @default(uuid())
  name            String
  email           String?
  isPlusOne       Boolean      @default(false)
  amount          Float        @default(0)
  date            DateTime     @default(now())
  registryItem    RegistryItem? @relation(fields: [registryItemId], references: [id], onDelete: Cascade)
  registryItemId  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ContentNode {
  id        String   @id @default(uuid())
  type      String   // e.g., "FAQ", "Logistics", "Photo"
  tags      String[] // e.g., ["Homepage", "FAQ"]
  data      Json     // Flexible key-value pairs
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SnapshotVersion {
  id          String   @id @default(uuid())
  entityType  String   // "AppConfig", "ContentNode", "RegistryItem", etc.
  entityId    String   // The ID of the modified entity
  data        Json     // Full snapshot of the record at the time of save
  author      String   @default("Admin")
  createdAt   DateTime @default(now())
}


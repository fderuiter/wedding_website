{
  "name": "wedding_website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "node --experimental-strip-types scripts/generate-docs.ts",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "pretest": "sh ./scripts/pretest.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:a11y": "rm -rf test-results && npm test; npx playwright test; node scripts/a11y-report.mjs",
    "migrate:dev": "dotenv -e .env.development.local -- prisma migrate dev",
    "migrate:deploy": "dotenv -e .env.development.local -- prisma migrate deploy",
    "db:seed": "node --experimental-strip-types --import ./scripts/register.mjs scripts/seed.ts",
    "prisma:generate": "prisma generate",
    "scaffold": "node scripts/scaffold-feature.mjs"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@hello-pangea/dnd": "^18.0.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/config": "^7.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@tanstack/react-query": "^5.90.20",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "dotenv-cli": "^11.0.0",
    "framer-motion": "^12.34.0",
    "ics": "^3.8.1",
    "keen-slider": "^6.8.6",
    "leaflet": "^1.9.4",
    "maath": "^0.10.8",
    "next": "^16.2.6",
    "node-html-parser": "^8.0.4",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "three": "^0.182.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^7.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.170.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "msw": "^1.3.3",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.5",
    "typescript": "^5",
    "zod-to-json-schema": "^3.25.2"
  }
